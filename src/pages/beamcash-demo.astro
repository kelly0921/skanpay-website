---
import BaseLayout from "../layouts/BaseLayout.astro";

const sessionStates = [
  {
    label: "Created",
    detail: "Merchant creates a checkout request with amount, location, and session reference."
  },
  {
    label: "Scanned",
    detail: "Customer opens the request through the BeamCash mobile flow."
  },
  {
    label: "Authorized",
    detail: "Customer approves, cancels, or leaves the request pending."
  },
  {
    label: "Confirmed",
    detail: "Merchant receives a readable checkout result."
  }
];

const demoPayload = `{
  "session_id": "demo_8F42",
  "merchant": "Sample Market",
  "amount": "24.80",
  "currency": "USD",
  "status": "authorized",
  "mode": "sandbox"
}`;
---
<BaseLayout
  title="BeamCash Demo - SkanPay"
  description="View a controlled BeamCash sandbox walkthrough for QR checkout sessions, customer approval, and merchant confirmation."
  activePath="/beamcash-demo/"
>
  <section class="page-hero">
    <p class="eyebrow">BeamCash demo</p>
    <h1>QR checkout workflow, shown as a sandbox demo</h1>
    <p>
      BeamCash shows how a merchant request, customer approval, and checkout confirmation can work together.
    </p>
  </section>

  <section class="section demo-layout">
    <div>
      <p class="eyebrow">Demo purpose</p>
      <h2>Help prospects understand the payment states before integration work begins</h2>
      <p class="section-intro">
        The demo is useful for merchant conversations, wallet partner reviews, and internal product alignment.
      </p>
      <div class="notice-panel">
        <strong>Sandbox only</strong>
        <p>This walkthrough is illustrative. It should not collect card, bank, wallet, or personal payment credentials.</p>
      </div>
    </div>

    <aside class="demo-console" aria-label="BeamCash sandbox session summary">
      <div class="demo-console-header">
        <span>Session</span>
        <strong>BeamCash sandbox</strong>
      </div>
      <div class="demo-flow-map" aria-label="BeamCash participant flow">
        <span>Merchant request</span>
        <span>Customer approval</span>
        <span>Checkout result</span>
      </div>
      <div class="demo-metric-grid">
        <div>
          <span>Status</span>
          <strong>Authorized</strong>
        </div>
        <div>
          <span>Mode</span>
          <strong>Sandbox</strong>
        </div>
        <div>
          <span>Channel</span>
          <strong>QR checkout</strong>
        </div>
        <div>
          <span>Result</span>
          <strong>Readable</strong>
        </div>
      </div>
      <pre class="payload-block"><code>{demoPayload}</code></pre>
    </aside>
  </section>

  <section class="section technical-band">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Walkthrough states</p>
        <h2>A simple state model for checkout conversations</h2>
      </div>
      <p>
        Each state gives a technical buyer enough context to discuss store behavior, app behavior, and support needs.
      </p>
    </div>
    <div class="state-track">
      {sessionStates.map((state, index) => (
        <article>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{state.label}</h3>
          <p>{state.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split">
    <div class="split-panel">
      <p class="eyebrow">Merchant view</p>
      <h2>What the counter team needs to know</h2>
      <ul>
        <li>The request amount and checkout reference are visible.</li>
        <li>The customer action is separated from the merchant result.</li>
        <li>Pending, cancelled, expired, and authorized states are easy to explain.</li>
        <li>The final screen makes the next counter action clear.</li>
      </ul>
    </div>
    <div class="split-panel">
      <p class="eyebrow">Customer view</p>
      <h2>What the customer experiences</h2>
      <ul>
        <li>Scan or open the QR payment request.</li>
        <li>Review the merchant name, amount, and session details.</li>
        <li>Approve or cancel inside the sandbox flow.</li>
        <li>Return to checkout with a clear final status.</li>
      </ul>
    </div>
  </section>

  <section class="cta-band">
    <div>
      <p class="eyebrow">Next step</p>
      <h2>Use the demo to guide a focused integration conversation.</h2>
      <p>Share which merchant, wallet, or partner flow you want the BeamCash walkthrough to represent.</p>
    </div>
    <a class="button secondary" href="/contact/">Request a Demo</a>
  </section>
</BaseLayout>
