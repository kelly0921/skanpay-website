---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="About - SkanPay"
  description="Learn about SkanPay's patent-pending QR payment gateway work and the team building practical merchant checkout experiences."
  activePath="/about/"
>
  <section class="page-hero">
    <p class="eyebrow">About SkanPay</p>
    <h1>Building practical QR payment infrastructure for in-store commerce</h1>
    <p>Patent-pending QR payment gateway work for checkout coordination, redemption logic, payment apps, and partners.</p>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Team</p>
        <h2>The team behind SkanPay</h2>
      </div>
      <p>Payment expertise, product implementation, and partner-facing business development.</p>
    </div>
    <div class="team-grid">
      <article class="team-card">
        <div class="avatar-placeholder" aria-hidden="true">KC</div>
        <span>Product and implementation</span>
        <h3>Kelly Chen</h3>
        <p>Kelly leads product direction, user experience, and implementation for SkanPay and the BeamCash demo.</p>
      </article>
      <article class="team-card">
        <div class="avatar-placeholder" aria-hidden="true">BC</div>
        <span>Payment expertise</span>
        <h3>Bilin Chen</h3>
        <p>Bilin brings payment-industry knowledge across gateway models, merchant acceptance, and in-store transaction flow.</p>
      </article>
      <article class="team-card">
        <div class="avatar-placeholder" aria-hidden="true">ZL</div>
        <span>Business and market development</span>
        <h3>Zoe Lu</h3>
        <p>Zoe supports business development, market communication, and partner-facing positioning.</p>
      </article>
    </div>
  </section>

  <section class="section patent-band">
    <div>
      <p class="eyebrow">Invention</p>
      <h2>Patent-pending QR payment gateway work</h2>
      <p>
        SkanPay has pending patent work related to QR payment acceptance, checkout coordination, and coupon or voucher redemption flows.
      </p>
    </div>
    <a class="button primary" href="/contact/">Discuss SkanPay</a>
  </section>
</BaseLayout>
