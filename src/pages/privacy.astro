---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Privacy Policy - SkanPay"
  description="SkanPay privacy policy for website visitors and contact inquiries."
  activePath="/privacy/"
>
  <section class="page-hero">
    <p class="eyebrow">Privacy</p>
    <h1>Privacy Policy</h1>
    <p>This policy explains the basic information SkanPay may receive through this website and how inquiries are handled.</p>
  </section>

  <section class="section">
    <div class="split-panel">
      <h2>Website inquiries</h2>
      <p>SkanPay may receive contact details you choose to provide, such as your name, email address, company, inquiry type, and message.</p>
      <h2>Use of information</h2>
      <p>Information submitted through the website is used to respond to questions, cooperation requests, merchant inquiries, or partnership discussions.</p>
      <h2>Analytics and cookies</h2>
      <p>The redesigned site does not require tracking cookies by default. If analytics are added later, this page should be updated to describe the tool and data collected.</p>
      <h2>Contact</h2>
      <p>For privacy-related questions, contact <a href="mailto:support@skanpay.us">support@skanpay.us</a>.</p>
    </div>
  </section>
</BaseLayout>
